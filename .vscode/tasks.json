{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo build agent",
      "type": "shell",
      "command": "cargo build",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "${env:HOME}/.cargo/bin:${env:PATH}"
        }
      },
      "group": "build",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "build ui-sdk",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/ui-sdk"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "build agent ui",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/ui"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "build agent all",
      "dependsOn": ["build agent ui", "build ui-sdk", "cargo build agent"],
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "build and dev agent ui",
      "dependsOn": ["npm: dev - agent ui"],
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "npm: dev - agent ui",
      "type": "shell",
      "command": "npm run dev -- --host 0.0.0.0 --port 5173",
      "options": {
        "cwd": "${workspaceFolder}/ui"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:.*5173"
        }
      }
    }
  ]
}
